# Environment Configuration Template
# Copy this to .env and fill in your actual values

# Application Environment
ENVIRONMENT=development
DEBUG=true
API_URL=http://localhost:8000

# LLM Configuration
# Groq (Mixtral 8x7B) is the wired provider. Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Web Search Integration
# Get free API key from https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Database Configuration (optional)
DATABASE_URL=sqlite:///./rag.db

# Docker Configuration
DOCKER_USERNAME=your_docker_username
DOCKER_TOKEN=your_docker_token

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# EC2 Configuration
EC2_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx
EC2_USERNAME=ubuntu
EC2_KEY_PATH=/path/to/your/key.pem

# GitHub Configuration
GITHUB_TOKEN=your_github_token
GITHUB_REPO_OWNER=Amith-Ganta
GITHUB_REPO_NAME=Rag-fullstack-docker-AWS

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Security
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
